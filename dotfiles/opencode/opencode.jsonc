{
  "$schema": "https://opencode.ai/config.json",
  "shell": "zsh",
  "disabled_providers": [],
  // 2026-07-13: the "shellac" provider (http://10.10.10.5:11434, qwen2.5-coder:32b) was REMOVED —
  // shellac + toolbelt are POWERED DOWN and the free rail is deprecated. OpenCode was still
  // pointed at that dead endpoint. Backup of the old config: opencode.jsonc.bak.20260713-shellac.
  // Rationale: claude-fleet/models.json -> tiers.free_worker. Cheap inference now = DeepInfra.
  "provider": {
    "deepinfra": {
      "name": "deepinfra",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.deepinfra.com/v1/openai",
        "apiKey": "{env:DEEPINFRA_API_KEY}"
      },
      "models": {
        "Qwen/Qwen3-Coder-480B-A35B-Instruct": {
          "name": "qwen3-coder-480b (cheap rail primary)"
        },
        "deepseek-ai/DeepSeek-V3.1": {
          "name": "deepseek-v3.1 (cheap rail fallback)"
        },
        // gemma-4-31B-it WON Jason's 6-model cheap bake-off — and STILL LOST to Sonnet-5 in a
        // 5-day live A/B on the Morning Email Recon summarizer (2026-07-13 verdict). It MISSED
        // real customer emails and an about-to-incur LATE-FEE notice that Sonnet caught. One
        // surfaced past-due notice outweighs a YEAR of token savings. Listed here for code-grind
        // errands ONLY — do NOT reach for it for triage/summarization of high-signal work.
        // See blackbook: 2026-07-13-verdict-2026-07-13-jason-after.
        "google/gemma-4-31B-it": {
          "name": "gemma-4-31b (cheap bake-off winner — REJECTED for high-signal work)"
        }
      }
    }
  }
}
